# Heimdell CRM Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# NETLIFY DB (NEON POSTGRES) - Required for Netlify Functions
# ============================================================================
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ============================================================================
# OPTIONAL: Supabase configuration (for auth)
# ============================================================================
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# See apps/api/.env.example and apps/web/.env.example for specific configs
